# TomiLomos API - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains secrets

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/tomilomos

# ============================================================================
# JWT AUTHENTICATION (REQUIRED)
# ============================================================================
# Secret key for JWT signing. Use a strong random string in production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_super_secret_key_change_me_in_production

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# JWT token expiration time in hours (default: 24)
JWT_EXPIRATION_HOURS=24

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Bcrypt hashing cost factor (default: 12)
# Must be between 10 and 31. Higher values = slower hashing = more secure
# Set to 10 for development (faster), 12+ for production
BCRYPT_COST=12

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Server port (default: 8000)
PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed CORS origins (comma-separated or JSON array)
# For development: http://localhost:3000
# For production: https://yourdomain.com
CORS_ORIGINS=["http://localhost:3000"]

# ============================================================================
# NOTES FOR PRODUCTION
# ============================================================================
# 1. Change JWT_SECRET to a strong random value
# 2. Set BCRYPT_COST to 12 or higher
# 3. Use environment-specific .env files or secrets management
# 4. Never commit actual secrets to version control
# 5. Use HTTPS in production (set secure=True on cookies)
# 6. Disable debug logging (LOG_LEVEL=WARNING or ERROR)
